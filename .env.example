# Configuración de Redis
REDIS_URL=redis://localhost:6379/0

# Seguridad y Autenticación
# Generar claves con: openssl rand -hex 32
JWT_SECRET=8e68fb263cd735d464ad19e6231d6837a28e8ee0f7a77e8a9bc6f62b6623d38f
JWT_REFRESH_SECRET=7f5dfa364be14b8a4f9104bfa5649ee628ee8d88e0b66ea5abc7a6e19cbef8bc
