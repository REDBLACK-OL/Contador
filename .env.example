# Entorno: development, staging, production
ENV=development

# Configuración del Servidor
PROJECT_NAME="WordCount Pro"
API_V1_STR="/api/v1"
HOST=0.0.0.0
PORT=8000

# Base de Datos PostgreSQL (Async URL)
